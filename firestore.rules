rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this app, we'll allow the owner (shahar.dolev@gmail.com) to be admin
      return isAuthenticated() && 
             (request.auth.token.email == "shahar.dolev@gmail.com" && request.auth.token.email_verified == true);
    }

    // Settings: Admin can write, anyone can read (needed for backend bot)
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reports: Admin can read/write, anyone can create (needed for backend bot)
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }
  }
}
